rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only authenticated users (including anonymous) can access rooms.
    // No other collections are exposed.
    match /rooms/{roomCode} {

      // Allow reads to any authenticated user who knows the room code.
      allow read: if request.auth != null;

      // Allow creating a new room only if:
      //   - The caller is authenticated
      //   - The hostId field matches the caller's UID (prevents spoofing)
      //   - Required fields are present and correctly typed
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.keys().hasAll(['hostId', 'page', 'kids', 'timer', 'level', 'hits', 'shotsFired', 'startTime', 'totalWins', 'players', 'lastUpdate'])
        && request.resource.data.page is string
        && request.resource.data.kids is list
        && request.resource.data.timer is number
        && request.resource.data.level is number
        && request.resource.data.hits is number
        && request.resource.data.shotsFired is number;

      // Allow updates to authenticated users only.
      // Prevent changing the hostId or players list arbitrarily:
      //   - Only the host can advance the page or update kids/timer/level
      //   - Any player can add themselves to the players array
      allow update: if request.auth != null
        // hostId must not change
        && request.resource.data.hostId == resource.data.hostId
        // A non-host can only add themselves to players (join action)
        && (
          request.auth.uid == resource.data.hostId
          || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['players', 'kids'])
          )
        );

      // Only the host can delete a room
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.hostId;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
